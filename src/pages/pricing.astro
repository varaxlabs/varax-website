---
import Base from '@layouts/Base.astro';
import Button from '@components/Button.astro';
import SectionHeading from '@components/SectionHeading.astro';

const checkIcon = `<svg class="w-4 h-4 text-success shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>`;
const xIcon = `<svg class="w-4 h-4 text-light-text-secondary shrink-0 mt-0.5 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12" /></svg>`;

const freeTier = {
  name: 'Free',
  price: { monthly: '$0', annual: '$0' },
  description: 'Core compliance scanning for every Kubernetes team.',
  cta: { label: 'Install Free', href: '/docs/compliance/quickstart' },
  features: [
    { text: '109 security checks (CIS, NSA/CISA, SOC2, PSS)', included: true },
    { text: 'Terminal compliance summary', included: true },
    { text: 'JSON output for CI/CD', included: true },
    { text: 'Dry-run remediation preview', included: true },
    { text: 'BoltDB scan history', included: true },
    { text: 'Audit-ready PDF/HTML reports', included: false },
    { text: 'Full evidence packages', included: false },
    { text: 'Auto-remediation', included: false },
    { text: 'Priority email support', included: false },
  ],
};

const proTier = {
  name: 'Pro',
  price: { monthly: '$149', annual: '$1,490' },
  period: { monthly: '/month', annual: '/year' },
  description: 'Audit-ready reports and auto-remediation for teams that need SOC2.',
  cta: { label: 'Buy Pro', href: '#' }, // Stripe integration TBD
  features: [
    { text: '109 security checks (CIS, NSA/CISA, SOC2, PSS)', included: true },
    { text: 'Terminal compliance summary', included: true },
    { text: 'JSON output for CI/CD', included: true },
    { text: 'Dry-run remediation preview', included: true },
    { text: 'BoltDB scan history', included: true },
    { text: 'Audit-ready PDF/HTML reports', included: true },
    { text: 'Full evidence packages', included: true },
    { text: 'Auto-remediation', included: true },
    { text: 'Priority email support', included: true },
  ],
};

const enterpriseFeatures = [
  { title: 'Conversational CLI', desc: 'Ask Varax why a control is failing - in plain English.' },
  { title: 'On-Cluster AI', desc: 'No external API calls. Intelligence runs inside your cluster.' },
  { title: 'Remediation as Code', desc: 'Generate exact kubectl commands and YAML to fix findings.' },
  { title: 'Time-Travel Compliance', desc: '13+ months of compliance history for auditors.' },
  { title: 'Multi-Cluster Support', desc: 'Aggregate compliance across all clusters.' },
  { title: 'Dedicated Support', desc: 'Private Slack channel with SLA.' },
];

const faqs = [
  {
    q: 'What happens when my license expires?',
    a: 'Varax continues scanning and producing terminal output — you never lose visibility. Pro features (HTML reports, auto-remediation, evidence packages) are disabled until you renew. There\'s a 5-day grace period after expiration.',
  },
  {
    q: 'Can I try Pro before buying?',
    a: 'The free tier runs the same 109 checks as Pro. The difference is output format and automation. View our sample report to see exactly what Pro generates.',
  },
  {
    q: 'Is there a per-node or per-cluster fee?',
    a: 'No. Flat rate. One license covers one cluster regardless of size. Need multiple clusters? Contact us for volume pricing.',
  },
  {
    q: 'Do I need to send data to your servers?',
    a: 'No. Varax runs entirely in your cluster. No data ever leaves your infrastructure. License validation uses an offline Ed25519 signature — no phone-home required.',
  },
  {
    q: 'What\'s your refund policy?',
    a: '30-day money-back guarantee, no questions asked. If Varax doesn\'t save you time on your next audit, we\'ll refund your purchase.',
  },
  {
    q: 'Do you offer annual billing?',
    a: 'Yes — annual billing saves you two months ($298/year). Toggle the pricing above to see annual rates.',
  },
  {
    q: 'When will Enterprise be available?',
    a: 'We\'re targeting Q3 2026. Join the waitlist to be notified when it launches and to get early access.',
  },
  {
    q: 'What does "on-cluster AI" mean?',
    a: 'Unlike tools that send your data to external AI providers, Varax Enterprise runs a specialized compliance model entirely inside your Kubernetes cluster. Your scan results, findings, and questions never leave your infrastructure. This is critical for air-gapped environments and regulated industries.',
  },
  {
    q: 'Can I get Enterprise features in Pro?',
    a: 'The conversational CLI and on-cluster AI require significant additional compute resources and are architected differently from the Pro tier. They\'ll remain Enterprise-only. However, all the core compliance scanning, evidence generation, and reporting in Pro will continue to improve.',
  },
  {
    q: 'Is there a trial for Enterprise?',
    a: 'We\'ll offer a 30-day trial for qualified companies when Enterprise launches. Join the waitlist to be notified.',
  },
];
---

<Base title="Pricing" description="Simple, flat-rate pricing for Kubernetes compliance automation. Free tier included.">

  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-8">
    <div class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-semibold text-light-text mb-4">
        Simple pricing. No per-node fees.
      </h1>
      <p class="text-base text-light-text-secondary max-w-xl mx-auto mb-8">
        One flat rate per cluster. The free tier is free forever.
      </p>

      <!-- Billing Toggle -->
      <div class="flex items-center justify-center gap-3 text-sm">
        <span id="label-monthly" class="font-semibold text-light-text">Monthly</span>
        <button
          id="billing-toggle"
          type="button"
          class="relative w-12 h-6 rounded-full bg-light-border transition-colors"
          aria-label="Toggle annual billing"
        >
          <span id="toggle-knob" class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-accent transition-transform"></span>
        </button>
        <span id="label-annual" class="text-light-text-secondary">
          Annual <span class="text-accent text-xs font-semibold ml-1">Save $298</span>
        </span>
      </div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <!-- Free -->
      <div class="p-8 rounded-xl border border-light-border bg-light-surface">
        <h2 class="text-xl font-semibold text-light-text mb-1">{freeTier.name}</h2>
        <div class="mb-4">
          <span class="text-3xl font-semibold text-light-text">$0</span>
          <span class="text-light-text-secondary text-sm"> forever</span>
        </div>
        <p class="text-sm text-light-text-secondary mb-6">{freeTier.description}</p>
        <Button href={freeTier.cta.href} variant="secondary" class="w-full mb-8">{freeTier.cta.label}</Button>
        <ul class="space-y-3">
          {freeTier.features.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-light-text">
              <Fragment set:html={f.included ? checkIcon : xIcon} />
              <span class:list={[!f.included && 'opacity-40']}>{f.text}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Pro -->
      <div class="relative p-8 rounded-xl border-2 border-accent bg-light-surface">
        <span class="absolute -top-3 left-6 text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full bg-accent text-white">Popular</span>
        <h2 class="text-xl font-semibold text-light-text mb-1">{proTier.name}</h2>
        <div class="mb-4">
          <span id="pro-price" class="text-3xl font-semibold text-light-text">$149</span>
          <span id="pro-period" class="text-light-text-secondary text-sm">/month</span>
        </div>
        <p class="text-sm text-light-text-secondary mb-6">{proTier.description}</p>
        <!-- Stripe Checkout button — href will be replaced with Stripe Checkout URL -->
        <Button href={proTier.cta.href} class="w-full mb-8">{proTier.cta.label}</Button>
        <ul class="space-y-3">
          {proTier.features.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-light-text">
              <Fragment set:html={checkIcon} />
              {f.text}
            </li>
          ))}
        </ul>
      </div>

      <!-- Enterprise -->
      <div id="enterprise" class="relative p-8 rounded-xl border border-light-border bg-light-surface opacity-90">
        <span class="absolute -top-3 left-6 text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full bg-light-text-secondary text-white">Coming Q3 2026</span>
        <h2 class="text-xl font-semibold text-light-text mb-1">Enterprise</h2>
        <div class="mb-4">
          <span class="text-lg font-semibold text-light-text-secondary">Contact Us</span>
        </div>
        <p class="text-sm text-light-text-secondary mb-6">Air-gapped intelligence for regulated industries. Everything in Pro, plus:</p>

        <!-- Waitlist CTA — expands to inline form on click -->
        <div id="enterprise-waitlist">
          <button
            id="waitlist-btn"
            type="button"
            class="w-full mb-8 inline-flex items-center justify-center rounded-lg border border-light-border bg-light-surface px-4 py-2.5 text-sm font-semibold text-light-text hover:border-accent hover:text-accent transition-colors"
          >
            Join the Waitlist &rarr;
          </button>

          <form id="waitlist-form" class="hidden mb-8 space-y-3">
            <input
              type="email"
              name="email"
              required
              placeholder="you@company.com"
              class="w-full rounded-lg border border-light-border bg-white px-3 py-2 text-sm text-light-text placeholder:text-light-text-secondary focus:outline-none focus:border-accent"
            />
            <input
              type="text"
              name="company"
              placeholder="Company (optional)"
              class="w-full rounded-lg border border-light-border bg-white px-3 py-2 text-sm text-light-text placeholder:text-light-text-secondary focus:outline-none focus:border-accent"
            />
            <select
              name="clusters"
              class="w-full rounded-lg border border-light-border bg-white px-3 py-2 text-sm text-light-text focus:outline-none focus:border-accent"
            >
              <option value="">How many clusters?</option>
              <option value="1">1</option>
              <option value="2-5">2-5</option>
              <option value="6-10">6-10</option>
              <option value="10+">10+</option>
            </select>
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center rounded-lg bg-accent px-4 py-2.5 text-sm font-semibold text-white hover:bg-accent-dark transition-colors"
            >
              Join Waitlist
            </button>
            <p class="text-xs text-light-text-secondary text-center">No spam. Just launch updates.</p>
          </form>

          <div id="waitlist-success" class="hidden mb-8 rounded-lg border border-success/30 bg-success/5 p-4 text-center">
            <svg class="w-5 h-5 text-success mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7" /></svg>
            <p class="text-sm text-light-text">You're on the list. We'll email you when Enterprise launches.</p>
          </div>
        </div>

        <ul class="space-y-3">
          {enterpriseFeatures.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-light-text">
              <Fragment set:html={checkIcon} />
              <span><strong class="font-semibold">{f.title}</strong> - {f.desc}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="text-center text-sm text-light-text-secondary mt-8">
      All plans include 109 security checks across CIS, NSA/CISA, SOC2, and PSS benchmarks.
      <br />30-day money-back guarantee on Pro.
    </p>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <SectionHeading title="Frequently Asked Questions" />
    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="group border border-light-border rounded-lg">
          <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-sm font-semibold text-light-text">
            {faq.q}
            <svg class="w-4 h-4 shrink-0 ml-4 transition-transform group-open:rotate-180 text-light-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-4 text-sm text-light-text-secondary">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </section>

</Base>

<script>
  function initBillingToggle() {
    const toggle = document.getElementById('billing-toggle');
    const knob = document.getElementById('toggle-knob');
    const labelMonthly = document.getElementById('label-monthly');
    const labelAnnual = document.getElementById('label-annual');
    const proPrice = document.getElementById('pro-price');
    const proPeriod = document.getElementById('pro-period');
    if (!toggle || !knob || !labelMonthly || !labelAnnual || !proPrice || !proPeriod) return;

    let isAnnual = false;

    toggle.addEventListener('click', () => {
      isAnnual = !isAnnual;
      knob.style.transform = isAnnual ? 'translateX(1.5rem)' : 'translateX(0)';
      proPrice.textContent = isAnnual ? '$1,490' : '$149';
      proPeriod.textContent = isAnnual ? '/year' : '/month';
      labelMonthly.classList.toggle('text-light-text-secondary', isAnnual);
      labelMonthly.classList.toggle('font-semibold', !isAnnual);
      labelAnnual.classList.toggle('text-light-text', isAnnual);
      labelAnnual.classList.toggle('font-semibold', isAnnual);
    });
  }

  initBillingToggle();
  document.addEventListener('astro:after-swap', initBillingToggle);
</script>

<script>
  function initEnterpriseWaitlist() {
    const btn = document.getElementById('waitlist-btn');
    const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
    const success = document.getElementById('waitlist-success');
    if (!btn || !form || !success) return;

    btn.addEventListener('click', () => {
      btn.classList.add('hidden');
      form.classList.remove('hidden');
      const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
      emailInput?.focus();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const email = formData.get('email') as string;
      const company = formData.get('company') as string;
      const clusters = formData.get('clusters') as string;

      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';
      }

      try {
        const res = await fetch('/api/waitlist/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            tag: 'enterprise-waitlist',
            ...(company && { company }),
            ...(clusters && { clusters }),
          }),
        });

        if (res.ok) {
          form.classList.add('hidden');
          success.classList.remove('hidden');
        } else {
          const data = await res.json();
          alert(data.error || 'Something went wrong. Please try again.');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Join Waitlist';
          }
        }
      } catch {
        alert('Something went wrong. Please try again.');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Join Waitlist';
        }
      }
    });
  }

  initEnterpriseWaitlist();
  document.addEventListener('astro:after-swap', initEnterpriseWaitlist);
</script>
