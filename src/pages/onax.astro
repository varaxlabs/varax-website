---
import Base from '@layouts/Base.astro';
import Button from '@components/Button.astro';
import CodeBlock from '@components/CodeBlock.astro';
import SectionHeading from '@components/SectionHeading.astro';
import CrossPromo from '@components/CrossPromo.astro';
---

<Base title="Onax" description="Open-source CronJob monitoring for Kubernetes. Know when jobs fail, hang, or miss their schedule — without writing a single PromQL query.">

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-16">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent mb-3">Onax</p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold text-light-text leading-tight mb-4">
        Open-source CronJob monitoring<br class="hidden sm:block" /> for Kubernetes.
      </h1>
      <p class="text-lg text-light-text-secondary max-w-2xl mx-auto mb-8">
        Know when jobs fail, hang, or miss their schedule — without writing a single PromQL query.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <Button href="/docs/monitor/quickstart" size="lg">Get Started</Button>
        <Button href="https://github.com/varaxlabs/onax" variant="secondary" size="lg" external>View on GitHub</Button>
      </div>
    </div>

    <!-- Terminal Demo -->
    <div class="rounded-lg overflow-hidden border border-code-border bg-code-bg shadow-lg max-w-2xl mx-auto">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-code-border bg-code-titlebar">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#FEBC2E]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
        </div>
        <span class="text-xs text-code-text-secondary font-mono ml-2">terminal</span>
      </div>
      <div class="p-4 sm:p-6 font-mono text-sm leading-relaxed">
        <div><span class="text-accent">$</span><span class="text-code-text"> helm install onax varaxlabs/onax</span></div>
        <div class="text-code-text-secondary">NAME: onax</div>
        <div class="text-code-text-secondary">STATUS: deployed</div>
        <div class="text-code-text-secondary">REVISION: 1</div>
        <div class="mt-3"><span class="text-accent">$</span><span class="text-code-text"> kubectl get pods -l app=onax</span></div>
        <div class="text-code-text-secondary">NAME &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;READY &nbsp; STATUS</div>
        <div><span class="text-code-text-secondary">onax-7f8b9c &nbsp; &nbsp;1/1 &nbsp; &nbsp;</span><span class="text-success">Running</span></div>
        <div class="mt-3"><span class="text-success">&#10003;</span><span class="text-code-text"> Monitoring 14 CronJobs across 3 namespaces</span></div>
        <div><span class="text-success">&#10003;</span><span class="text-code-text"> Prometheus metrics exposed on :9090/metrics</span></div>
      </div>
    </div>
  </section>

  <!-- Problem / Solution -->
  <section class="border-y border-light-border bg-light-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-error mb-3">The Problem</h2>
          <h3 class="text-xl font-semibold text-light-text mb-4">
            Kubernetes CronJobs fail silently.
          </h3>
          <p class="text-base text-light-text-secondary">
            Your nightly backup didn't run? Your report generator has been broken for a week? You won't know until someone complains.
            Existing solutions are either expensive SaaS tools that require per-job configuration, or hours of DIY Prometheus PromQL wrangling.
          </p>
        </div>
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-success mb-3">The Solution</h2>
          <h3 class="text-xl font-semibold text-light-text mb-4">
            One Helm command. Zero configuration.
          </h3>
          <p class="text-base text-light-text-secondary mb-4">
            Every CronJob monitored automatically. Onax uses Kubernetes Informers to detect every CronJob in your cluster
            and exports clean Prometheus metrics. No per-job setup. No annotations. It just works.
          </p>
          <CodeBlock title="terminal" code="$ helm install onax varaxlabs/onax\n✓ Monitoring 14 CronJobs across 3 namespaces" />
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <SectionHeading title="Everything you need for CronJob observability" />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { title: 'Auto-Discovery', desc: 'Detects every CronJob in your cluster automatically using Kubernetes Informers. Add a new CronJob? It\'s monitored instantly.' },
        { title: 'Pre-Built Dashboards', desc: 'Import the included Grafana dashboard and see all your CronJobs in one view. Execution history, success rates, duration trends.' },
        { title: 'Smart Alert Rules', desc: 'Pre-configured Prometheus alerts for job failures, missed schedules, abnormal duration, and stuck jobs.' },
        { title: 'Prometheus Native', desc: 'Exports clean, well-labeled Prometheus metrics. Works with your existing monitoring stack. No new tools to learn.' },
        { title: 'Lightweight', desc: 'Under 50MB memory, under 0.05 CPU. Read-only cluster access. No persistent storage needed.' },
        { title: 'Open Source', desc: 'Apache 2.0 licensed. No telemetry. No vendor lock-in. Free forever.' },
      ].map((feature) => (
        <div class="p-6 rounded-xl border border-light-border bg-light-surface">
          <h3 class="text-base font-semibold text-light-text mb-2">{feature.title}</h3>
          <p class="text-sm text-light-text-secondary">{feature.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Metrics Reference -->
  <section class="border-y border-light-border bg-light-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <SectionHeading title="Metrics at a glance" subtitle="Clean, well-labeled Prometheus metrics for every CronJob in your cluster." />

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-light-border">
              <th class="text-left py-3 px-4 font-semibold text-light-text">Metric</th>
              <th class="text-left py-3 px-4 font-semibold text-light-text">Type</th>
              <th class="text-left py-3 px-4 font-semibold text-light-text">Description</th>
            </tr>
          </thead>
          <tbody class="text-light-text-secondary">
            {[
              { metric: 'cronjob_last_execution_status', type: 'Gauge', desc: 'Last execution result (1=success, 0=failure)' },
              { metric: 'cronjob_last_execution_duration_seconds', type: 'Gauge', desc: 'Duration of last execution' },
              { metric: 'cronjob_execution_total', type: 'Counter', desc: 'Total executions (labeled success/failure)' },
              { metric: 'cronjob_missed_schedules_total', type: 'Counter', desc: 'Missed schedule count' },
              { metric: 'cronjob_next_schedule_time', type: 'Gauge', desc: 'Unix timestamp of next expected run' },
              { metric: 'cronjob_is_suspended', type: 'Gauge', desc: 'Whether the CronJob is suspended' },
            ].map((row) => (
              <tr class="border-b border-light-border">
                <td class="py-3 px-4 font-mono text-xs text-accent">{row.metric}</td>
                <td class="py-3 px-4">{row.type}</td>
                <td class="py-3 px-4">{row.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Cross Promo -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <CrossPromo />
  </section>

  <!-- Final CTA -->
  <section class="border-t border-light-border bg-light-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24 text-center">
      <h2 class="text-2xl sm:text-3xl font-semibold text-light-text mb-4">
        Monitor every CronJob in your cluster.
      </h2>
      <div class="max-w-xl mx-auto mb-8">
        <CodeBlock title="terminal">$ helm install onax varaxlabs/onax</CodeBlock>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <Button href="/docs/monitor/quickstart" size="lg">Install Now</Button>
        <Button href="/docs/monitor/quickstart" variant="secondary" size="lg">Read the Docs</Button>
        <Button href="https://github.com/varaxlabs/onax" variant="ghost" size="lg" external>Star on GitHub</Button>
      </div>
    </div>
  </section>

</Base>
