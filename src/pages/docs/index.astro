---
import Base from '@layouts/Base.astro';
import Button from '@components/Button.astro';
---

<Base title="Documentation" description="Varax documentation hub. Guides and references for Onax and Varax Compliance.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 class="text-3xl sm:text-4xl font-semibold text-light-text mb-4">Documentation</h1>
    <p class="text-base text-light-text-secondary mb-12">
      Guides, references, and tutorials for Varax products.
    </p>

    <div class="grid sm:grid-cols-2 gap-6">
      <!-- Monitor Docs -->
      <a href="/docs/monitor/quickstart" class="group block p-6 rounded-xl border border-light-border hover:border-accent/50 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-sm font-semibold uppercase tracking-wider px-2 py-0.5 rounded bg-accent/10 text-accent">Free</span>
        </div>
        <h2 class="text-lg font-semibold text-light-text group-hover:text-accent transition-colors mb-2">
          Onax
        </h2>
        <p class="text-sm text-light-text-secondary mb-4">
          Kubernetes CronJob monitoring with Prometheus. Quickstart, metrics reference, dashboards, and alert rules.
        </p>
        <span class="text-sm text-accent font-medium">Get started &rarr;</span>
      </a>

      <!-- Compliance Docs -->
      <a href="/docs/compliance/quickstart" class="group block p-6 rounded-xl border border-light-border hover:border-accent/50 transition-colors">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-sm font-semibold uppercase tracking-wider px-2 py-0.5 rounded bg-accent/10 text-accent">Pro</span>
        </div>
        <h2 class="text-lg font-semibold text-light-text group-hover:text-accent transition-colors mb-2">
          Varax Compliance
        </h2>
        <p class="text-sm text-light-text-secondary mb-4">
          SOC2 compliance automation for Kubernetes. Installation, configuration, scanning, reports, and remediation.
        </p>
        <span class="text-sm text-accent font-medium">Get started &rarr;</span>
      </a>
    </div>
  </div>
</Base>
