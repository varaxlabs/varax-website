---
import Base from '@layouts/Base.astro';
import Button from '@components/Button.astro';
import TerminalDemo from '@components/TerminalDemo.astro';
import CodeBlock from '@components/CodeBlock.astro';
import SectionHeading from '@components/SectionHeading.astro';
---

<Base title="Varax" description="SOC2 compliance for Kubernetes. One CLI command. Auto-discovers misconfigurations, maps to controls, generates audit-ready reports.">

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold text-light-text leading-tight mb-4">
        SOC2 compliance for Kubernetes.<br class="hidden sm:block" /> One CLI command.
      </h1>
      <p class="text-lg text-light-text-secondary max-w-2xl mx-auto mb-8">
        Auto-discovers misconfigurations. Maps to SOC2 controls. Generates the PDF your auditor wants. And your data never leaves your cluster.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <Button href="/docs/compliance/quickstart" size="lg">Install Varax</Button>
        <Button href="/onax" variant="secondary" size="lg">Try Onax &rarr;</Button>
      </div>
    </div>

    <TerminalDemo />
  </section>

  <!-- Data Sovereignty -->
  <section class="border-y border-light-border bg-light-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <h2 class="text-2xl sm:text-3xl font-semibold text-light-text mb-10">Your compliance data stays yours.</h2>
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div class="space-y-4 text-base text-light-text-secondary leading-relaxed">
          <p>Most compliance tools want your cluster data on their servers. Varax doesn't.</p>
          <p>No SaaS dashboard phoning home. No vendor with a copy of your cluster topology. No API keys to rotate when they get breached.</p>
          <p>Varax runs entirely inside your cluster — air-gapped compatible, SOC2-ready, enterprise-approved.</p>
        </div>
        <div class="rounded-lg overflow-hidden border border-code-border bg-code-bg shadow-lg">
          <div class="flex items-center gap-2 px-4 py-2.5 border-b border-code-border bg-code-titlebar">
            <div class="flex gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
              <span class="w-3 h-3 rounded-full bg-[#FEBC2E]"></span>
              <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
            </div>
            <span class="text-xs text-code-text-secondary font-mono ml-2">terminal</span>
          </div>
          <div class="p-4 sm:p-6 font-mono text-sm leading-relaxed">
            <div><span class="text-accent">$</span><span class="text-code-text"> netstat -an | grep varax</span></div>
            <div class="mt-3 text-code-text-secondary">(no external connections)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Integration Bar -->
  <section class="border-b border-light-border bg-light-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12 text-light-text-secondary">
        <div class="flex items-center gap-2.5" title="Kubernetes">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M10.204 14.35l.007.01-.999 2.413a5.171 5.171 0 0 1-2.075-2.597l2.578-.437.004.005a.44.44 0 0 1 .484.606zm-.833-2.129a.44.44 0 0 0 .173-.756l.002-.011L7.585 9.7a5.143 5.143 0 0 0-.73 3.255l2.514-.725.002-.009zm1.145-1.98a.44.44 0 0 0 .699-.337l.01-.005.15-2.62a5.144 5.144 0 0 0-3.01 1.442l2.147 1.523.004-.002zm.76 2.75l.723.349.722-.347.18-.78-.5-.623h-.804l-.5.623.179.779zm1.5-3.095a.44.44 0 0 0 .7.336l.008.003 2.134-1.513a5.188 5.188 0 0 0-2.992-1.442l.148 2.615.002.001zm10.876 5.97l-5.773 7.181a1.6 1.6 0 0 1-1.248.594l-9.261.003a1.6 1.6 0 0 1-1.247-.596l-5.776-7.18a1.583 1.583 0 0 1-.307-1.34L2.1 5.573c.108-.47.425-.864.863-1.073L11.305.513a1.606 1.606 0 0 1 1.385 0l8.345 3.985c.438.209.755.604.863 1.073l2.062 8.955c.108.47-.005.963-.308 1.34zm-3.289-2.057c-.042-.01-.103-.026-.145-.034-.174-.033-.315-.025-.479-.038-.35-.037-.638-.067-.895-.148-.105-.04-.18-.165-.216-.216l-.201-.059a6.45 6.45 0 0 0-.105-2.332 6.465 6.465 0 0 0-.936-2.163c.052-.047.15-.133.177-.159.008-.09.001-.183.094-.282.197-.185.444-.338.743-.522.142-.084.273-.137.415-.242.032-.024.076-.062.11-.089.24-.191.295-.52.123-.736-.172-.216-.506-.236-.745-.045-.034.027-.08.062-.111.088-.134.116-.217.23-.33.35-.246.25-.45.458-.673.609-.097.056-.239.037-.303.033l-.19.135a6.545 6.545 0 0 0-4.146-2.003l-.012-.223c-.065-.062-.143-.115-.163-.25-.022-.268.015-.557.057-.905.023-.163.061-.298.068-.475.001-.04-.001-.099-.001-.142 0-.306-.224-.555-.5-.555-.275 0-.499.249-.499.555l.001.014c0 .041-.002.092 0 .128.006.177.044.312.067.475.042.348.078.637.056.906a.545.545 0 0 1-.162.258l-.012.211a6.424 6.424 0 0 0-4.166 2.003 8.373 8.373 0 0 1-.18-.128c-.09.012-.18.04-.297-.029-.223-.15-.427-.358-.673-.608-.113-.12-.195-.234-.329-.349-.03-.026-.077-.062-.111-.088a.594.594 0 0 0-.348-.132.481.481 0 0 0-.398.176c-.172.216-.117.546.123.737l.007.005.104.083c.142.105.272.159.414.242.299.185.546.338.743.522.076.082.09.226.1.288l.16.143a6.462 6.46