          <span class="text-sm font-medium">Kubernetes</span>
        </div>
        <div class="flex items-center gap-2.5" title="Helm">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12.337 0c-.475 0-.861 1.016-.861 2.269 0 .527.069 1.011.183 1.396a8.514 8.514 0 0 0-3.961 1.22 5.229 5.229 0 0 0-.595-1.093c-.606-.866-1.34-1.436-1.79-1.43a.381.381 0 0 0-.217.066c-.39.273-.123 1.326.596 2.353.267.381.559.705.84.948a8.683 8.683 0 0 0-1.528 1.716h1.734a7.179 7.179 0 0 1 5.381-2.421 7.18 7.18 0 0 1 5.382 2.42h1.733a8.687 8.687 0 0 0-1.32-1.53c.35-.249.735-.643 1.078-1.133.719-1.027.986-2.08.596-2.353a.382.382 0 0 0-.217-.065c-.45-.007-1.184.563-1.79 1.43a4.897 4.897 0 0 0-.676 1.325 8.52 8.52 0 0 0-3.899-1.42c.12-.39.193-.887.193-1.429 0-1.253-.386-2.269-.862-2.269zM1.624 9.443v5.162h1.358v-1.968h1.64v1.968h1.357V9.443H4.62v1.838H2.98V9.443zm5.912 0v5.162h3.21v-1.108H8.893v-.95h1.64v-1.142h-1.64v-.84h1.853V9.443zm4.698 0v5.162h3.218v-1.362h-1.86v-3.8zm4.706 0v5.162h1.364v-2.643l1.357 1.225 1.35-1.232v2.65h1.365V9.443h-.614l-2.1 1.914-2.109-1.914zm-11.82 7.28a8.688 8.688 0 0 0 1.412 1.548 5.206 5.206 0 0 0-.841.948c-.719 1.027-.985 2.08-.596 2.353.39.273 1.289-.338 2.007-1.364a5.23 5.23 0 0 0 .595-1.092 8.514 8.514 0 0 0 3.961 1.219 5.01 5.01 0 0 0-.183 1.396c0 1.253.386 2.269.861 2.269.476 0 .862-1.016.862-2.269 0-.542-.072-1.04-.193-1.43a8.52 8.52 0 0 0 3.9-1.42c.121.4.352.865.675 1.327.719 1.026 1.617 1.637 2.007 1.364.39-.273.123-1.326-.596-2.353-.343-.49-.727-.885-1.077-1.135a8.69 8.69 0 0 0 1.202-1.36h-1.771a7.174 7.174 0 0 1-5.227 2.252 7.174 7.174 0 0 1-5.226-2.252z"/></svg>
          <span class="text-sm font-medium">Helm</span>
        </div>
        <div class="flex items-center gap-2.5" title="Prometheus">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.372 0 12c0 6.627 5.373 12 12 12s12-5.373 12-12c0-6.628-5.373-12-12-12zm0 22.46c-1.885 0-3.414-1.26-3.414-2.814h6.828c0 1.553-1.528 2.813-3.414 2.813zm5.64-3.745H6.36v-2.046h11.28v2.046zm-.04-3.098H6.391c-.037-.043-.075-.086-.111-.13-1.155-1.401-1.427-2.133-1.69-2.879-.005-.025 1.4.287 2.395.511 0 0 .513.119 1.262.255-.72-.843-1.147-1.915-1.147-3.01 0-2.406 1.845-4.508 1.18-6.207.648.053 1.34 1.367 1.387 3.422.689-.951.977-2.69.977-3.755 0-1.103.727-2.385 1.454-2.429-.648 1.069.168 1.984.894 4.256.272.854.237 2.29.447 3.201.07-1.892.395-4.652 1.595-5.605-.529 1.2.079 2.702.494 3.424.671 1.164 1.078 2.047 1.078 3.716a4.642 4.642 0 01-1.11 2.996c.792-.149 1.34-.283 1.34-.283l2.573-.502s-.374 1.538-1.81 3.019z"/></svg>
          <span class="text-sm font-medium">Prometheus</span>
        </div>
        <div class="flex items-center gap-2.5" title="Slack">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg>
          <span class="text-sm font-medium">Slack</span>
        </div>
        <div class="flex items-center gap-2.5" title="Amazon EKS">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="m14.67 8.505-2.875 3.335 3.128 3.648h-1.168l-2.808-3.277v3.368h-.842V8.421h.842v2.947l2.603-2.863Zm7.225 6.751-3.369-2.021V8.421a.42.42 0 0 0-.209-.364l-4.843-2.825V1.159l8.42 4.976Zm.635-9.724L13.267.06a.422.422 0 0 0-.635.362v5.053c0 .15.08.288.208.363l4.844 2.826v4.81a.42.42 0 0 0 .205.362l4.21 2.526a.42.42 0 0 0 .638-.361V5.895a.42.42 0 0 0-.207-.363ZM11.977 23.1l-9.872-5.248V6.135l8.421-4.976v4.084L6.09 8.066a.422.422 0 0 0-.195.355v7.158a.42.42 0 0 0 .226.373l5.665 2.948a.42.42 0 0 0 .387 0l5.496-2.84 3.382 2.03Zm10.135-5.356-4.21-2.526a.42.42 0 0 0-.411-.013l-5.51 2.847-5.244-2.729v-6.67l4.436-2.824a.422.422 0 0 0 .195-.355V.42a.421.421 0 0 0-.635-.362L1.47 5.532a.421.421 0 0 0-.207.363v12.21c0 .156.086.299.223.372l10.297 5.474a.421.421 0 0 0 .401-.004l9.915-5.473a.422.422 0 0 0 .013-.73Z"/></svg>
          <span class="text-sm font-medium">AWS EKS</span>
        </div>
        <div class="flex items-center gap-2.5" title="GitHub">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          <span class="text-sm font-medium">GitHub</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <SectionHeading title="Built for Kubernetes teams" subtitle="Everything you need for Kubernetes compliance, nothing you don't." />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { title: 'Auto-Discovery', desc: 'Scans your entire cluster automatically. No configuration files to maintain.' },
        { title: 'SOC2 Control Mapping', desc: 'Every check maps to specific SOC2 Trust Services Criteria.' },
        { title: 'Audit-Ready Reports', desc: 'Generate the PDF your auditor needs with one CLI command.' },
        { title: 'Auto-Enable Audit Logging', desc: 'Programmatically enables K8s audit logging on EKS, AKS, and GKE.' },
        { title: 'Auto-Remediation', desc: 'Opt-in fixes for failing checks with dry-run mode.' },
        { title: 'CIS Benchmark Checks', desc: 'Validates against CIS Kubernetes Benchmarks with HIPAA and PCI-DSS on the roadmap.' },
      ].map((feature) => (
        <div class="p-6 rounded-xl border border-light-border bg-light-surface">
          <h3 class="text-base font-semibold text-light-text mb-2">{feature.title}</h3>
          <p class="text-sm text-light-text-secondary">{feature.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How It Works -->
  <section class="border-y border-light-border bg-light-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <SectionHeading title="How It Works" subtitle="From install to compliance report in three steps." />

      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-accent text-white text-sm font-semibold">1</span>
            <h3 class="text-lg font-semibold text-light-text">Install</h3>
          </div>
          <CodeBlock title="terminal">helm install varax varaxlabs/operator</CodeBlock>
        </div>

        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-accent text-white text-sm font-semibold">2</span>
            <h3 class="text-lg font-semibold text-light-text">Scan</h3>
          </div>
          <CodeBlock title="terminal" code={`<span class="text-accent">$</span> varax scan\n<span class="text-success">&#10003;</span> RBAC Configuration\n<span class="text-success">&#10003;</span> Network Policies\n<span class="text-warning">&#9888;</span> Pod Security Standards\n\nScore: <span class="text-success">87/100</span>`} />
        </div>

        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-accent text-white text-sm font-semibold">3</span>
            <h3 class="text-lg font-semibold text-light-text">Report</h3>
          </div>
          <CodeBlock title="terminal" code={`<span class="text-accent">$</span> varax report --format pdf\n\n<span class="text-success">&#10003;</span> Report generated\n  varax-soc2-report.pdf (42 pages)`} />
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24 text-center">
    <h2 class="text-2xl sm:text-3xl font-semibold text-light-text mb-4">
      Ready to see your compliance score?
    </h2>
    <p class="text-base text-light-text-secondary mb-8 max-w-xl mx-auto">
      Install in 60 seconds. No credit card, no sign-up, no vendor lock-in.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <Button href="/docs/compliance/quickstart" size="lg">Install Varax — takes 60 seconds</Button>
      <Button href="/sample-report" variant="secondary" size="lg">View Sample Report</Button>
    </div>
  </section>

</Base>
