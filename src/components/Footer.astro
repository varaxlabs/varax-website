---
const columns = [
  {
    title: 'Products',
    links: [
      { label: 'Varax Compliance', href: '/' },
      { label: 'Varax Monitor', href: '/monitor' },
      { label: 'Pricing', href: '/pricing' },
      { label: 'Sample Report', href: '/sample-report' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Compliance Docs', href: '/docs/compliance/quickstart' },
      { label: 'Monitor Docs', href: '/docs/monitor/quickstart' },
      { label: 'Blog', href: '/blog' },
      { label: 'Changelog', href: '/changelog' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Consulting', href: '/consulting' },
      { label: 'GitHub', href: 'https://github.com/varaxlabs', external: true },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Service', href: '/terms' },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-light-border bg-light-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {columns.map((col) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-light-text-secondary mb-4">
            {col.title}
          </h3>
          <ul class="space-y-2">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-light-text hover:text-accent transition-colors"
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-light-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-light-text-secondary">
        &copy; {year} Varax Labs. All rights reserved.
      </p>
      <a
        href="https://github.com/varaxlabs"
        target="_blank"
        rel="noopener noreferrer"
        class="text-light-text-secondary hover:text-light-text transition-colors"
        aria-label="Varax Labs on GitHub"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
