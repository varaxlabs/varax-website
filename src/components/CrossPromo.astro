---
import Button from './Button.astro';
---

<section class="border border-light-border rounded-xl bg-light-surface p-8 sm:p-10">
  <div class="max-w-2xl">
    <p class="text-xs font-semibold uppercase tracking-wider text-accent mb-3">Onax + Varax</p>
    <h3 class="text-xl sm:text-2xl font-semibold text-light-text mb-3">
      Full observability and compliance in one stack.
    </h3>
    <p class="text-base text-light-text-secondary mb-6">
      Varax scans your Kubernetes cluster for SOC2 violations and generates audit-ready reports with one CLI command.
      Same Kubernetes-native approach. Same zero-config philosophy.
    </p>
    <div class="flex flex-wrap gap-3">
      <Button href="/" variant="secondary">Learn about Varax Compliance</Button>
    </div>
  </div>
</section>
