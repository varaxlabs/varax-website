---
interface Props {
  title?: string;
  code?: string;
  class?: string;
}

const { title, code, class: className = '' } = Astro.props;
---

<div class:list={['rounded-lg overflow-hidden border border-dark-border bg-dark-surface', className]}>
  {title && (
    <div class="flex items-center gap-2 px-4 py-2.5 border-b border-dark-border bg-dark-bg">
      <div class="flex gap-1.5">
        <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FEBC2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
      </div>
      <span class="text-xs text-dark-text-secondary font-mono ml-2">{title}</span>
    </div>
  )}
  <div class="p-4 overflow-x-auto">
    {code ? (
      <pre class="text-sm font-mono text-dark-text leading-relaxed" set:html={code} />
    ) : (
      <pre class="text-sm font-mono text-dark-text leading-relaxed"><slot /></pre>
    )}
  </div>
</div>
