---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { title, subtitle, align = 'center', class: className = '' } = Astro.props;
const alignClass = align === 'center' ? 'text-center' : 'text-left';
---

<div class:list={[alignClass, 'mb-12', className]}>
  <h2 class="text-2xl sm:text-3xl font-semibold text-light-text dark:text-dark-text">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-3 text-base text-light-text-secondary dark:text-dark-text-secondary max-w-2xl" class:list={[align === 'center' && 'mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
