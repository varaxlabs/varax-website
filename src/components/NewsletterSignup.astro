---
---

<div class="rounded-xl border border-light-border bg-light-surface p-6 sm:p-8">
  <h3 class="text-lg font-semibold text-light-text mb-2">Stay in the loop</h3>
  <p class="text-sm text-light-text-secondary mb-4">
    Get Kubernetes operations tips, new feature announcements, and compliance guides. No spam.
  </p>
  <form class="flex flex-col sm:flex-row gap-3" action="#" method="POST">
    <input
      type="email"
      name="email"
      required
      placeholder="you@company.com"
      class="flex-1 px-4 py-2.5 text-sm rounded-lg border border-light-border bg-light-bg text-light-text placeholder:text-light-text-secondary focus:outline-none focus:ring-2 focus:ring-accent/50"
    />
    <button
      type="submit"
      class="px-5 py-2.5 text-sm font-semibold rounded-lg bg-accent text-white hover:bg-accent-light transition-colors shrink-0"
    >
      Subscribe
    </button>
  </form>
</div>
